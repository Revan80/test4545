<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const prestationHeaders = document.querySelectorAll('.prestation-header');
    
    prestationHeaders.forEach(function(header) {
      header.addEventListener('click', function() {
        const targetId = this.dataset.target;
        const content = document.getElementById(targetId);
        const isActive = this.classList.contains('active');
        
        // Fermer tous les autres accordéons
        prestationHeaders.forEach(function(h) {
          h.classList.remove('active');
          const otherId = h.dataset.target;
          const otherContent = document.getElementById(otherId);
          if (otherContent) {
            otherContent.classList.remove('active');
          }
        });
        
        // Ouvrir/fermer la prestation cliquée
        if (!isActive && content) {
          this.classList.add('active');
          content.classList.add('active');
        }
      });
    });
  });
</script>
