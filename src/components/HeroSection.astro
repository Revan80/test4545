---
// HeroSection.astro - Composant hero mobile-first pour La Cabane de Lucie
---

<section class="flex flex-col relative overflow-hidden" style="background-image: url('/images/photoHero.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat; min-height: 65.6vh;">
  <!-- Header -->
  <header class="flex items-center justify-end p-6 relative z-10">
    <!-- Menu Hamburger -->
    <button 
      class="flex flex-col gap-1.5 p-2 transition-transform duration-300 hover:scale-110 group"
      aria-label="Menu"
    >
      <span class="w-6 h-0.5 bg-white transition-all duration-300 group-hover:bg-gray-200"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300 group-hover:bg-gray-200"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300 group-hover:bg-gray-200"></span>
    </button>
  </header>

  <!-- Contenu Principal Aligné à Gauche -->
  <div class="flex-1 flex flex-col justify-center px-6 md:px-18 lg:px-16 -mt-32 md:-mt-28">
    
    <!-- Tagline avec plus d'espace -->
    <div class="mb-8 md:mb-10">
      <p class="text-sm md:text-base font-medium tracking-extra-wide uppercase" style="color: #ffffff !important; margin-top: 25px; margin-bottom: 55px;">
        HAIR SPA & COIFFURE
      </p>
    </div>

    <!-- Espacement pour maintenir la position des éléments -->
    <div class="mb-6 md:mb-8">
    </div>

    <!-- Bloc inférieur compact : Avis Google + Bouton -->
    <div class="space-y-4" style="margin-top: -75px; margin-bottom: 15%;">
      <!-- Widget Google Avis - Plus discret -->
      <div class="inline-flex items-center bg-white rounded-md px-3 py-2 shadow-sm border border-gray-100 max-w-fit opacity-90">
        <!-- Logo Google plus petit -->
        <div class="flex items-center mr-2">
          <div class="w-5 h-5 bg-white rounded flex items-center justify-center mr-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <span class="text-xs font-medium text-gray-700">Google</span>
        </div>
        
        <!-- Étoiles et notation plus petites -->
        <div class="flex items-center">
          <!-- 5 étoiles style Google plus petites -->
          <div class="flex items-center mr-1.5">
            <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          
          <!-- Note et nombre d'avis plus petits -->
          <div class="flex items-center">
            <span class="text-xs font-medium text-gray-800 mr-1">4,9</span>
            <span class="text-xs text-gray-500"></span>
          </div>
        </div>
      </div>

      <!-- Bouton Call-to-Action rapproché -->
      <div>
        <a href="https://www.planity.com/la-cabane-de-lucie-31000-toulouse" target="_blank" rel="noopener noreferrer" class="inline-flex items-center btn-hover-lift bg-white px-4 py-3 rounded-lg text-sm font-playfair font-semibold focus:outline-none focus:ring-4 focus:ring-white/30 transition-all duration-300 shadow-sm border border-gray-100 max-w-fit opacity-90" style="color: #7B4A2B;">
          Prendre rendez-vous
        </a>
      </div>
    </div>
  </div>

  <!-- Espacement en bas réduit de moitié -->
  <div class="h-8 md:h-10"></div>
</section>
